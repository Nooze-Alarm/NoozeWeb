---
const { minimal = false } = Astro.props;
---
{minimal ? (
<footer class="footer-gradient border-t border-white/5">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 text-center text-gray-600 text-sm">
        <p>&copy; 2025-2026 Nooze Alarm. All rights reserved.</p>
    </div>
</footer>
) : (
<footer class="footer-gradient border-t border-white/5">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
            <div>
                <a href="index.html" class="text-xl font-bold text-white mb-4 inline-block">
                    Nooze<span class="text-primary">Alarm</span>
                </a>
                <p class="text-gray-500 text-sm leading-relaxed">
                    The intelligent alarm clock that tracks your sleep, wakes you at the perfect moment, and turns mornings into a rewarding experience.
                </p>
            </div>

            <div>
                <h4 class="text-white font-semibold mb-4">Navigation</h4>
                <ul class="space-y-2 text-sm">
                    <li><a href="index.html" class="text-gray-400 hover:text-primary transition-colors">Home</a></li>
                    <li><a href="features.html" class="text-gray-400 hover:text-primary transition-colors">Features</a></li>
                    <li><a href="about.html" class="text-gray-400 hover:text-primary transition-colors">About</a></li>
                    <li><a href="faq.html" class="text-gray-400 hover:text-primary transition-colors">FAQ</a></li>
                    <li><a href="contact.html" class="text-gray-400 hover:text-primary transition-colors">Contact</a></li>
                    <li><a href="support.html" class="text-gray-400 hover:text-primary transition-colors">Support Us</a></li>
                    <li><a href="roadmap.html" class="text-gray-400 hover:text-primary transition-colors">Roadmap</a></li>
                </ul>
            </div>

            <div>
                <h4 class="text-white font-semibold mb-4">Legal</h4>
                <ul class="space-y-2 text-sm">
                    <li><a href="privacy.html" class="text-gray-400 hover:text-primary transition-colors">Privacy Policy</a></li>
                    <li><a href="terms.html" class="text-gray-400 hover:text-primary transition-colors">Terms and Conditions</a></li>
                </ul>
            </div>

            <div>
                <h4 class="text-white font-semibold mb-4">Get in Touch</h4>
                <p class="text-gray-500 text-sm mb-4">
                    <a href="mailto:noozesupport@gmail.com" class="text-gray-400 hover:text-primary transition-colors">noozesupport@gmail.com</a>
