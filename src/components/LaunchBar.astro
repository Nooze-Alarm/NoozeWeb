---
// Sitewide status ribbon. Dismissed via the global script (window.__dismissLaunchBar).
// Currently in "maintenance" mode while the app is unavailable on Google Play.
---
<a id="launchBar" class="launch-bar maintenance" href="support.html">
    <span class="shine"></span>
    <span class="pill"><span class="dot"></span>Maintenance</span>
    <span><strong><span class="hide-sm">Nooze Alarm is temporarily unavailable</span><span class="only-sm">Temporarily unavailable</span></strong><span class="hide-sm"> &mdash; downloads are paused while we work on bringing it back.</span></span>
    <span class="arrow">
        <span class="hide-sm">Learn more</span>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M13 6l6 6-6 6"/></svg>
    </span>
    <button type="button" class="close" aria-label="Dismiss status banner" onclick="event.preventDefault();event.stopPropagation();window.__dismissLaunchBar&&window.__dismissLaunchBar();">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 6l12 12M6 18L18 6"/></svg>
    </button>
</a>
