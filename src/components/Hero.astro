        .nz-phone { width: 280px; height: 574px; }
        .nz-floor { height: 34vh; }
    }

    @media (prefers-reduced-motion: reduce) {
        .nz-aurora-a, .nz-aurora-b, .nz-particle, .nz-badge-spin,
        .nz-badge-dot, .nz-live-dot, .nz-float, .nz-h1-grad {
            animation: none !important;
        }
    }
</style>

<script>
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const finePointer = window.matchMedia('(pointer: fine)').matches;

    // --- Waveform: rAF-driven, DOM-mutated, paused when offscreen ---
    const waveLine = document.getElementById('nzWaveLine');
    const waveFill = document.getElementById('nzWaveFill');
    const waveDot = document.getElementById('nzWaveDot');
    const hero = document.getElementById('nzHero');

    if (!reduceMotion && waveLine && waveFill && waveDot && hero) {
        let t = 0;
        let raf = 0;
        let running = false;

        const amp = (i, tt) =>
            52 - (Math.sin(i * 0.22 + tt) * 13 + Math.sin(i * 0.1 + tt * 0.6) * 18 + Math.sin(i * 0.53 + tt * 1.2) * 5);

        const buildLine = (tt) => {
            let s = 'M';
            for (let i = 0; i <= 60; i++) {
                s += (i ? ' L ' : '') + ((i / 60) * 340).toFixed(1) + ' ' + amp(i, tt).toFixed(1);
            }
            return s;
        };

        const loop = () => {
            t += 0.03;
            const d = buildLine(t);
            waveLine.setAttribute('d', d);
            waveFill.setAttribute('d', d + ' L 340 110 L 0 110 Z');
            waveDot.setAttribute('cy', amp(60, t).toFixed(1));
            raf = requestAnimationFrame(loop);
        };

        const io = new IntersectionObserver((entries) => {
            const visible = entries[0].isIntersecting;
            if (visible && !running) { running = true; loop(); }
            else if (!visible && running) { running = false; cancelAnimationFrame(raf); }
        }, { threshold: 0.05 });
        io.observe(hero);
    }

    // --- Phone 3D tilt + floating-badge parallax (desktop pointers only) ---
    const tilt = document.getElementById('nzTilt');
    const xp = document.getElementById('nzXp');
    const streak = document.getElementById('nzStreak');

    if (!reduceMotion && finePointer && hero && tilt) {
        hero.addEventListener('mousemove', (e) => {
            const r = hero.getBoundingClientRect();
            const px = (e.clientX - r.left) / r.width - 0.5;
            const py = (e.clientY - r.top) / r.height - 0.5;
            tilt.style.transform = `rotateY(${px * 15}deg) rotateX(${-py * 11}deg)`;
            if (xp) xp.style.transform = `translate(${px * 30}px, ${py * 30}px)`;
            if (streak) streak.style.transform = `translate(${px * -22}px, ${py * -20}px)`;
        });
        hero.addEventListener('mouseleave', () => {
            tilt.style.transform = 'rotateY(0) rotateX(0)';
            if (xp) xp.style.transform = 'translate(0,0)';
            if (streak) streak.style.transform = 'translate(0,0)';
        });
    }

    // --- Demo alarm toggle ---
    const toggle = document.getElementById('nzToggle');
    if (toggle) {
        toggle.addEventListener('click', () => {
            const on = toggle.classList.toggle('on');
            toggle.setAttribute('aria-pressed', on ? 'true' : 'false');
        });
    }
</script>
