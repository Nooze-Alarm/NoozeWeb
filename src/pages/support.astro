---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
    title={"Support Nooze – Buy Us a Coffee on Ko-fi"}
    description={"Support Nooze development by buying us a coffee on Ko-fi. Your contribution helps build better sleep technology for everyone."}
    keywords={"support nooze, donate nooze, nooze ko-fi, buy coffee nooze alarm"}
    canonical={"support.html"}
    ogTitle={"Support Nooze - Buy Us a Coffee"}
    ogDescription={"Help us build better sleep technology. Every coffee counts."}
    active={"support"}
>

  <Fragment slot="head">
    <script type="application/ld+json" set:html={"{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https://noozealarm.com/\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Support\",\"item\":\"https://noozealarm.com/support.html\"}]}"} />
  </Fragment>

<main class="flex-1 pt-16">
        <!-- Hero -->
        <section class="hero-bg pt-32 pb-20 relative overflow-hidden">
            <div class="aurora"></div>
            <div class="holo-grid tilt-grid"></div>
            <div class="orb orb-1"></div>
            <div class="orb orb-2"></div>
            <div class="scanlines"></div>
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative z-10">
                <span class="holo-chip mb-6 reveal"><span class="dot"></span> One-developer project</span>
                <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white mb-4 reveal delay-1 tracking-tight">Support <span class="iris-text">Nooze</span></h1>
                <p class="text-lg text-gray-400 max-w-2xl mx-auto reveal delay-2">A solo developer is shipping this. Every coffee keeps servers up, ad-free policy intact and new features rolling.</p>
            </div>
        </section>

        <div class="section-divider"></div>

        <!-- Ko-fi Section -->
        <section class="py-20">
            <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="grid md:grid-cols-2 gap-10 items-center">
                    <!-- CTA Card -->
                    <div class="reveal">
                        <div class="holo-card pulse-glow"><div class="holo-card-inner text-center" style="padding:36px;">
                            <div class="w-20 h-20 rounded-2xl bg-gradient-to-br from-primary/20 to-accent/10 border border-primary/30 flex items-center justify-center mx-auto mb-6 shadow-[0_0_30px_rgba(0,188,212,0.3)]">
                                <svg width="36" height="36" viewBox="0 0 24 24" fill="currentColor" class="text-primary"><path d="M23.881 8.948c-.773-4.085-4.859-4.593-4.859-4.593H.723c-.604 0-.679.798-.679.798s-.082 7.324-.022 11.822c.164 2.424 2.586 2.672 2.586 2.672s8.267-.023 11.966-.049c2.438-.426 2.683-2.566 2.658-3.734 4.352.24 7.422-2.831 6.649-6.916zm-11.062 3.511c-1.246 1.453-4.011 3.976-4.011 3.976s-.121.119-.31.023c-.076-.057-.108-.09-.108-.09-.443-.441-3.368-3.049-4.034-3.954-.709-.965-1.041-2.7-.091-3.71.951-1.01 3.005-1.086 4.363.407 0 0 1.565-1.782 3.468-.963 1.904.82 1.832 3.011.723 4.311zm6.173.478c-.928.116-1.682.028-1.682.028V7.284h1.77s1.971.551 1.971 2.638c0 1.913-.985 2.667-2.059 3.015z"/></svg>
                            </div>
                            <span class="holo-chip mb-3"><span class="dot"></span> Optional &amp; appreciated</span>
                            <h2 class="text-2xl font-bold text-white mb-3 mt-3">Buy Me a Coffee</h2>
                            <p class="text-gray-400 text-sm leading-relaxed mb-6">Nooze is built by one person. Your support keeps the servers up, the project ad-free and new features shipping faster.</p>
                            <a href="https://ko-fi.com/noozealarm" target="_blank" rel="noopener noreferrer" class="btn-primary w-full">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M23.881 8.948c-.773-4.085-4.859-4.593-4.859-4.593H.723c-.604 0-.679.798-.679.798s-.082 7.324-.022 11.822c.164 2.424 2.586 2.672 2.586 2.672s8.267-.023 11.966-.049c2.438-.426 2.683-2.566 2.658-3.734 4.352.24 7.422-2.831 6.649-6.916zm-11.062 3.511c-1.246 1.453-4.011 3.976-4.011 3.976s-.121.119-.31.023c-.076-.057-.108-.09-.108-.09-.443-.441-3.368-3.049-4.034-3.954-.709-.965-1.041-2.7-.091-3.71.951-1.01 3.005-1.086 4.363.407 0 0 1.565-1.782 3.468-.963 1.904.82 1.832 3.011.723 4.311zm6.173.478c-.928.116-1.682.028-1.682.028V7.284h1.77s1.971.551 1.971 2.638c0 1.913-.985 2.667-2.059 3.015z"/></svg>
                                <span>Support on Ko-fi</span>
                            </a>
                        </div></div>
                    </div>

                    <!-- What Your Support Does -->
                    <div class="reveal delay-1">
                        <h3 class="text-xl font-bold text-white mb-6">Where Your Support Goes</h3>
                        <div class="space-y-4">
                            <div class="flex items-start gap-4">
                                <div class="feature-icon !w-11 !h-11 !rounded-xl flex-shrink-0">
                                    <svg class="!w-5 !h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 12h14M12 5l7 7-7 7"/></svg>
                                </div>
                                <div>
                                    <h4 class="text-white font-medium mb-1">Servers &amp; Infrastructure</h4>
                                    <p class="text-gray-400 text-sm">Hosting, cloud sync and backend services that keep alarms, gamification and friends in sync.</p>
                                </div>
                            </div>
                            <div class="flex items-start gap-4">
                                <div class="feature-icon !w-11 !h-11 !rounded-xl flex-shrink-0">
                                    <svg class="!w-5 !h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>
                                </div>
                                <div>
                                    <h4 class="text-white font-medium mb-1">New Features</h4>
                                    <p class="text-gray-400 text-sm">More wake challenges, smarter sleep detection, sound packs and the things you ask for.</p>
                                </div>
                            </div>
                            <div class="flex items-start gap-4">
                                <div class="feature-icon !w-11 !h-11 !rounded-xl flex-shrink-0">
                                    <svg class="!w-5 !h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
                                </div>
                                <div>
                                    <h4 class="text-white font-medium mb-1">Keeping It Free &amp; Private</h4>
                                    <p class="text-gray-400 text-sm">Core stays free, no ads, biometrics stay on your device. That doesn&rsquo;t change.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <div class="section-divider"></div>

        <!-- Other Ways -->
        <section class="py-20">
            <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
                <h2 class="text-2xl font-bold text-white mb-4 reveal">Other Ways to Support</h2>
                <p class="text-gray-400 mb-10 max-w-xl mx-auto reveal delay-1">Not everyone can donate, and that's completely fine. Here are free ways to help Nooze grow.</p>
                <div class="grid sm:grid-cols-3 gap-6">
                    <div class="holo-card tilt reveal delay-1"><div class="holo-card-inner tilt-inner">
                        <div class="feature-icon mx-auto mb-4">
                            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/></svg>
                        </div>
                        <h3 class="text-white font-semibold mb-2">Rate &amp; Review</h3>
                        <p class="text-gray-400 text-sm">Leave a review on Google Play once we launch. It massively helps others discover Nooze.</p>
                    </div></div>
                    <div class="holo-card tilt reveal delay-2"><div class="holo-card-inner tilt-inner">
                        <div class="feature-icon mx-auto mb-4">
                            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"/></svg>
                        </div>
                        <h3 class="text-white font-semibold mb-2">Spread the Word</h3>
                        <p class="text-gray-400 text-sm">Tell a friend who hits snooze ten times. Share on socials. Word of mouth beats every ad.</p>
                    </div></div>
                    <div class="holo-card tilt reveal delay-3"><div class="holo-card-inner tilt-inner">
                        <div class="feature-icon mx-auto mb-4">
                            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z"/></svg>
                        </div>
                        <h3 class="text-white font-semibold mb-2">Give Feedback</h3>
                        <p class="text-gray-400 text-sm">Report bugs, suggest features, or send your gripes via <a href="contact.html" class="text-primary hover:underline">contact</a>. We read everything.</p>
                    </div></div>
                </div>
            </div>
        </section>
    </main>
</BaseLayout>
