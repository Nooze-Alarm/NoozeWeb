---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
    title={"404 - Page Not Found | Nooze Alarm"}
    description={"The page you're looking for doesn't exist. Head back to Nooze Alarm's homepage."}
    canonical={""}
    noindex={true}
    footer={"minimal"}
>

<main class="flex-1 flex items-center justify-center hero-bg relative pt-16 overflow-hidden">
        <div class="aurora"></div>
        <div class="holo-grid tilt-grid"></div>
        <div class="orb orb-1"></div>
        <div class="orb orb-2"></div>
        <div class="orb orb-3"></div>
        <div class="scanlines"></div>

        <div class="text-center px-4 relative z-10 max-w-2xl">
            <span class="holo-chip mb-6 reveal"><span class="dot"></span> Lost in the dark</span>
            <h1 class="text-[10rem] sm:text-[12rem] font-extrabold leading-none mb-2 reveal delay-1 tracking-tighter">
                <span class="iris-text">404</span>
            </h1>
            <h2 class="text-3xl md:text-4xl font-bold text-white mb-4 reveal delay-2">Page Not Found</h2>
            <p class="text-lg text-gray-400 mb-10 max-w-md mx-auto reveal delay-3">
                Looks like this page hit snooze. Head home, or skip ahead to features.
            </p>
            <div class="flex flex-wrap gap-4 justify-center reveal delay-3">
                <a href="index.html" class="btn-primary">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
                    <span>Go Home</span>
                </a>
                <a href="features.html" class="btn-outline"><span>See Features</span></a>
            </div>
        </div>
    </main>
</BaseLayout>
