---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
    title={"Nooze Features – Smart Wake, Sleep Tracking & Wake Challenges"}
    description={"Explore Nooze features: smart wake windows, hybrid sleep tracking, 7 wake challenges (NFC, math, photo & more), gamification, social duels and 12 themes."}
    keywords={"smart alarm features, sleep cycle tracker, wake up challenges, gamified alarm app, sleep stage detection, smart wake window, no snooze alarm, nfc alarm, math alarm"}
    canonical={"features.html"}
    ogTitle={"Nooze Features - Smart Alarm & Sleep Tracker"}
    ogDescription={"Smart wake, hybrid sleep tracking, 6 wake challenges, gamification, social duels and more."}
    active={"features"}
>

  <Fragment slot="head">
    <script type="application/ld+json" set:html={"{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https://noozealarm.com/\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Features\",\"item\":\"https://noozealarm.com/features.html\"}]}"} />
  </Fragment>

<main class="flex-1">
        <section class="hero-bg pt-32 pb-20 relative overflow-hidden">
            <div class="aurora"></div>
            <div class="holo-grid tilt-grid"></div>
            <div class="orb orb-1"></div>
            <div class="orb orb-3"></div>
            <div class="scanlines"></div>

            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center">
                <span class="holo-chip mb-6 reveal"><span class="dot"></span> Built around your sleep</span>
                <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white mb-6 reveal delay-1 tracking-tight">
                    Every <span class="iris-text">Feature</span><span class="text-white">,</span> Built to Wake You Better
                </h1>
                <p class="text-lg sm:text-xl text-gray-400 max-w-3xl mx-auto reveal delay-2 leading-relaxed">
                    Smart wake windows, hybrid sleep detection, seven wake challenges, gamification, social duels and 12 themes — all in one Android app, no snooze button anywhere.
                </p>
            </div>
        </section>

        <div class="section-divider"></div>

        <section class="py-24 relative">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="text-center mb-14">
                    <span class="holo-chip mb-4 reveal"><span class="dot"></span> Core technology</span>
                    <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4 reveal">Smart Wake <span class="gradient-text-cyan">Window</span></h2>
                    <p class="text-gray-400 max-w-2xl mx-auto text-lg reveal delay-1">
                        Pick a 15, 20 or 30 minute window before your alarm. Nooze fires when you're already in light sleep, never mid-REM.
                    </p>
                </div>

                <div class="grid md:grid-cols-3 gap-6">
                    <div class="holo-card tilt reveal delay-1"><div class="holo-card-inner tilt-inner">
                        <div class="feature-icon mb-5"><svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg></div>
                        <h3 class="text-xl font-semibold text-white mb-3">15 / 20 / 30 min</h3>
                        <p class="text-gray-400 leading-relaxed">Choose how loose the window is per alarm. Tighter for fixed schedules, wider for weekends.</p>
                    </div></div>
                    <div class="holo-card tilt reveal delay-2"><div class="holo-card-inner tilt-inner">
                        <div class="feature-icon mb-5"><svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3"/></svg></div>
                        <h3 class="text-xl font-semibold text-white mb-3">Hybrid Detection</h3>
                        <p class="text-gray-400 leading-relaxed">Combines wearable data, motion and ambient sound. Higher confidence wins; quiet nights still get tracked.</p>
                    </div></div>
                    <div class="holo-card tilt reveal delay-3"><div class="holo-card-inner tilt-inner">
                        <div class="feature-icon mb-5"><svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg></div>
                        <h3 class="text-xl font-semibold text-white mb-3">Gradual Volume Ramp</h3>
                        <p class="text-gray-400 leading-relaxed">Volume rises softly across the last few minutes so you ease into the morning instead of jolting awake.</p>
                    </div></div>
                </div>
            </div>
        </section>

        <div class="section-divider"></div>

        <section class="py-24 relative">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="text-center mb-14">
                    <span class="holo-chip mb-4 reveal"><span class="dot"></span> No snooze, ever</span>
                    <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4 reveal">Seven Wake <span class="gradient-text">Challenges</span></h2>
                    <p class="text-gray-400 max-w-2xl mx-auto text-lg reveal delay-1">
                        The alarm only stops when you prove you're awake. Pick one, mix several, choose a difficulty.
                    </p>
                </div>

                <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
                    <div class="holo-card tilt reveal delay-1"><div class="holo-card-inner tilt-inner">
                        <div class="feature-icon !w-12 !h-12 !rounded-xl mb-4"><svg class="!w-6 !h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg></div>
                        <h3 class="text-white font-semibold mb-1">Math</h3>
                        <p class="text-gray-400 text-sm leading-relaxed">Solve quick problems scaled to your difficulty.</p>
                    </div></div>
                    <div class="holo-card tilt reveal delay-2"><div class="holo-card-inner tilt-inner">
                        <div class="feature-icon !w-12 !h-12 !rounded-xl mb-4"><svg class="!w-6 !h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 10h16M4 14h10M4 18h10"/></svg></div>
                        <h3 class="text-white font-semibold mb-1">Memory</h3>
                        <p class="text-gray-400 text-sm leading-relaxed">Repeat a sequence — short-term memory wakes you fast.</p>
                    </div></div>
                    <div class="holo-card tilt reveal delay-3"><div class="holo-card-inner tilt-inner">
                        <div class="feature-icon !w-12 !h-12 !rounded-xl mb-4"><svg class="!w-6 !h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg></div>
                        <h3 class="text-white font-semibold mb-1">Shake</h3>
                        <p class="text-gray-400 text-sm leading-relaxed">Shake the phone to a target — gets blood moving instantly.</p>
                    </div></div>
                    <div class="holo-card tilt reveal delay-1"><div class="holo-card-inner tilt-inner">
                        <div class="feature-icon !w-12 !h-12 !rounded-xl mb-4"><svg class="!w-6 !h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5h2l1 7h12l1-7h2M5 21h2m10 0h2M9 12v5m6-5v5"/></svg></div>
                        <h3 class="text-white font-semibold mb-1">Typing</h3>
                        <p class="text-gray-400 text-sm leading-relaxed">Type a phrase accurately — no autocorrect to lean on.</p>
                    </div></div>
                    <div class="holo-card tilt reveal delay-1"><div class="holo-card-inner tilt-inner">
                        <div class="feature-icon !w-12 !h-12 !rounded-xl mb-4"><svg class="!w-6 !h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 4h6v6H4zM14 4h6v6h-6zM4 14h6v6H4zM14 14h6v6h-6z"/></svg></div>
                        <h3 class="text-white font-semibold mb-1">QR Scan</h3>
                        <p class="text-gray-400 text-sm leading-relaxed">Stick a QR in the kitchen — you have to leave bed to scan it.</p>
                    </div></div>
                    <div class="holo-card tilt reveal delay-2"><div class="holo-card-inner tilt-inner">
                        <div class="feature-icon !w-12 !h-12 !rounded-xl mb-4"><svg class="!w-6 !h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 9a2 2 0 012-2h.93a2 2 0 001.66-.9l.82-1.2A2 2 0 0110.07 4h3.86a2 2 0 011.66.9l.82 1.2A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/><circle cx="12" cy="13" r="3"/></svg></div>
                        <h3 class="text-white font-semibold mb-1">Photo</h3>
                        <p class="text-gray-400 text-sm leading-relaxed">Snap a target object Nooze recognises — proves you're up and moving.</p>
                    </div></div>
                    <div class="holo-card tilt reveal delay-3"><div class="holo-card-inner tilt-inner">
                        <div class="feature-icon !w-12 !h-12 !rounded-xl mb-4"><svg class="!w-6 !h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8.111 16.404a5.5 5.5 0 017.778 0M5.281 13.575a9.5 9.5 0 0113.438 0M2.45 10.745a13.5 13.5 0 0119.1 0M12 20h.01"/></svg></div>
                        <h3 class="text-white font-semibold mb-1">NFC Scan</h3>
                        <p class="text-gray-400 text-sm leading-relaxed">Tap an NFC tag stuck across the room. The alarm only stops once your phone touches it.</p>
                    </div></div>
                    <div class="holo-card tilt reveal delay-1 opacity-80"><div class="holo-card-inner tilt-inner relative">
                        <span class="absolute top-3 right-3 px-2 py-0.5 rounded-full text-[9px] font-semibold bg-accent/20 text-accent-light border border-accent/30" style="letter-spacing:0.14em;text-transform:uppercase;">Coming Soon</span>
                        <div class="feature-icon !w-12 !h-12 !rounded-xl mb-4"><svg class="!w-6 !h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 7h16M4 12h16M4 17h10"/></svg></div>
                        <h3 class="text-white font-semibold mb-1">Anagram</h3>
                        <p class="text-gray-400 text-sm leading-relaxed">Unscramble a word — light cognitive load, surprisingly effective.</p>
                    </div></div>
                </div>

                <p class="text-center text-gray-500 mt-10 text-sm reveal">Combine multiple challenges in one alarm. Pick easy, medium or hard. The harder you finish, the more XP.</p>
            </div>
        </section>

        <div class="section-divider"></div>

        <section class="py-24 relative">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="grid lg:grid-cols-2 gap-12 items-center">
                    <div class="reveal">
                        <span class="holo-chip mb-4"><span class="dot"></span> Hybrid sleep detection</span>
                        <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">Tracks <span class="gradient-text-cyan">Four Sleep Phases</span></h2>
                        <p class="text-gray-400 text-lg leading-relaxed mb-6">
                            Awake, Light, Deep and REM — detected through your phone's motion and microphone, fused with wearable data when you have one.
                        </p>
                        <ul class="space-y-3 text-gray-300">
                            <li class="flex items-start gap-3"><span class="text-primary mt-1">▸</span> Confidence-weighted detection: wearable &gt; on-body sensor fusion &gt; nightstand mic.</li>
                            <li class="flex items-start gap-3"><span class="text-primary mt-1">▸</span> Shared-bed mode raises the threshold so a partner's movement isn't logged as yours.</li>
                            <li class="flex items-start gap-3"><span class="text-primary mt-1">▸</span> Wearable-only mode skips on-phone sensors entirely if you trust your watch.</li>
                            <li class="flex items-start gap-3"><span class="text-primary mt-1">▸</span> Snore and sleep-talk events surfaced in your morning summary.</li>
                        </ul>
                    </div>
                    <div class="grid grid-cols-2 gap-4 reveal-scale">
                        <div class="metric"><div class="num"><span data-counter="4" data-duration="1200">0</span></div><div class="lbl">Sleep Phases</div><div class="desc">Awake · Light · Deep · REM</div></div>
                        <div class="metric"><div class="num"><span data-counter="30" data-duration="1500">0</span><span class="unit">s</span></div><div class="lbl">Sample Rate</div><div class="desc">A new data point every half-minute.</div></div>
                        <div class="metric"><div class="num"><span data-counter="100" data-duration="1800">0</span><span class="unit">%</span></div><div class="lbl">On-Device</div><div class="desc">Raw biometrics never leave your phone.</div></div>
                        <div class="metric"><div class="num">∞</div><div class="lbl">History</div><div class="desc">Quality, cycles and wake-ease scored every night.</div></div>
                    </div>
                </div>
            </div>
        </section>

        <div class="section-divider"></div>

        <section class="py-24 relative">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="text-center mb-14">
                    <span class="holo-chip mb-4 reveal"><span class="dot"></span> Mornings, made fun</span>
                    <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4 reveal"><span class="gradient-text">Gamification</span> &amp; Streaks</h2>
                    <p class="text-gray-400 max-w-2xl mx-auto text-lg reveal delay-1">
                        Earn XP for every wake, journal entry and streak day. Level up. Unlock achievements and titles.
                    </p>
                </div>

                <div class="grid md:grid-cols-3 gap-6">
                    <div class="holo-card tilt reveal delay-1"><div class="holo-card-inner tilt-inner">
                        <div class="feature-icon mb-5"><svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/></svg></div>
                        <h3 class="text-xl font-semibold text-white mb-3">XP &amp; Levels</h3>
                        <p class="text-gray-400 leading-relaxed">Up to 50 XP per wake (challenge bonus + speed + perfect). 3 XP per journal. 5 XP per streak day. 50 XP per achievement.</p>
                    </div></div>
                    <div class="holo-card tilt reveal delay-2"><div class="holo-card-inner tilt-inner">
                        <div class="feature-icon mb-5"><svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143z"/></svg></div>
                        <h3 class="text-xl font-semibold text-white mb-3">Quests &amp; Achievements</h3>
                        <p class="text-gray-400 leading-relaxed">Daily quests refresh every morning. Long-term achievements unlock for streaks, perfect wakes and milestones.</p>
                    </div></div>
                    <div class="holo-card tilt reveal delay-3"><div class="holo-card-inner tilt-inner">
                        <div class="feature-icon mb-5"><svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13.5.67s.74 2.65.74 4.8c0 2.06-1.35 3.73-3.41 3.73-2.07 0-3.63-1.67-3.63-3.73l.03-.36C5.21 7.51 4 10.62 4 14c0 4.42 3.58 8 8 8s8-3.58 8-8c0-5.39-2.59-10.22-6.5-13.33z"/></svg></div>
                        <h3 class="text-xl font-semibold text-white mb-3">Streaks &amp; Widget</h3>
                        <p class="text-gray-400 leading-relaxed">Daily wake streak surfaced everywhere — including a home-screen widget so it's the first thing you see.</p>
                    </div></div>
                </div>
            </div>
        </section>

        <div class="section-divider"></div>

        <section class="py-24 relative">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="grid lg:grid-cols-2 gap-10 items-center">
                    <div class="reveal-right">
                        <span class="holo-chip mb-4"><span class="dot"></span> Compete &amp; cheer</span>
                        <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">Friends, Leaderboards &amp; <span class="gradient-text">Wake Duels</span></h2>
                        <p class="text-gray-400 text-lg leading-relaxed mb-6">
                            Add friends, see who's killing their streak and challenge anyone to a duel: first to nail their wake routine wins.
                        </p>
                        <div class="grid sm:grid-cols-2 gap-4">
                            <div class="glass-card p-5"><h4 class="text-white font-semibold mb-1">Activity Feed</h4><p class="text-gray-400 text-sm">See friends' achievements, streak milestones and duel results.</p></div>
                            <div class="glass-card p-5"><h4 class="text-white font-semibold mb-1">Wake Duels</h4><p class="text-gray-400 text-sm">Challenge a friend over a date range. 100 XP for the winner.</p></div>
                            <div class="glass-card p-5"><h4 class="text-white font-semibold mb-1">Leaderboards</h4><p class="text-gray-400 text-sm">Friends-only ladder. No public scoreboards, no harassment surface.</p></div>
                            <div class="glass-card p-5"><h4 class="text-white font-semibold mb-1">Anti-Farming</h4><p class="text-gray-400 text-sm">One active duel per pair. No looping challenges to grind XP.</p></div>
                        </div>
                    </div>
                    <div class="reveal-left">
                        <div class="holo-card"><div class="holo-card-inner" style="padding:32px;">
                            <div class="text-xs uppercase tracking-widest text-primary mb-3">Wake Duel — 7 days</div>
                            <div class="flex items-center justify-between mb-6">
                                <div><div class="text-white font-bold">You</div><div class="text-3xl font-extrabold gradient-text">5,420</div><div class="text-xs text-gray-500">XP this week</div></div>
                                <div class="text-2xl font-bold text-gray-500">vs</div>
                                <div class="text-right"><div class="text-white font-bold">Alex</div><div class="text-3xl font-extrabold text-gray-300">4,890</div><div class="text-xs text-gray-500">XP this week</div></div>
                            </div>
                            <div class="h-2 rounded-full bg-white/5 overflow-hidden mb-2"><div class="h-full bg-gradient-to-r from-primary to-accent-light" style="width:53%"></div></div>
                            <div class="flex justify-between text-xs text-gray-500"><span>3 days left</span><span class="text-primary">+100 XP if you win</span></div>
                        </div></div>
                    </div>
                </div>
            </div>
        </section>

        <div class="section-divider"></div>

        <section class="py-24 relative">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="text-center mb-14">
                    <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4 reveal">And <span class="gradient-text-cyan">Much More</span></h2>
                </div>

                <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
                    <div class="holo-card tilt reveal delay-1"><div class="holo-card-inner tilt-inner">
                        <div class="feature-icon !w-12 !h-12 !rounded-xl mb-4"><svg class="!w-6 !h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg></div>
                        <h3 class="text-white font-semibold mb-2">Health Hub</h3>
                        <p class="text-gray-400 text-sm leading-relaxed">Connects through Health Connect — pulls sleep, heart-rate and SpO₂ data from compatible wearables and apps.</p>
                    </div></div>
                    <div class="holo-card tilt reveal delay-2"><div class="holo-card-inner tilt-inner">
                        <div class="feature-icon !w-12 !h-12 !rounded-xl mb-4"><svg class="!w-6 !h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg></div>
                        <h3 class="text-white font-semibold mb-2">Smart Home</h3>
                        <p class="text-gray-400 text-sm leading-relaxed">Trigger lights, blinds and devices on wake via Home Assistant. Bring up your bedroom on your schedule.</p>
                    </div></div>
                    <div class="holo-card tilt reveal delay-3"><div class="holo-card-inner tilt-inner">
                        <div class="feature-icon !w-12 !h-12 !rounded-xl mb-4"><svg class="!w-6 !h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3"/></svg></div>
                        <h3 class="text-white font-semibold mb-2">Sleep Aids</h3>
                        <p class="text-gray-400 text-sm leading-relaxed">Calming soundscapes — rain, ocean, white noise — to help you drift off. Auto-fade so they don't run all night.</p>
                    </div></div>
                    <div class="holo-card tilt reveal delay-1"><div class="holo-card-inner tilt-inner">
                        <div class="feature-icon !w-12 !h-12 !rounded-xl mb-4"><svg class="!w-6 !h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg></div>
                        <h3 class="text-white font-semibold mb-2">Sleep Journal</h3>
                        <p class="text-gray-400 text-sm leading-relaxed">Log mood, energy, dreams and notes against each session. Patterns surface over weeks, not screenshots.</p>
                    </div></div>
                    <div class="holo-card tilt reveal delay-2"><div class="holo-card-inner tilt-inner">
